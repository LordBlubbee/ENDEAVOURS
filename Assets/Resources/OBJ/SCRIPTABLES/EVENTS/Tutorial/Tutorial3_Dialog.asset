MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 76cc7d0c0c139b946aecbf9c43b324e5, type: 3}
  m_Name: Tutorial3_Dialog
  m_EditorClassIdentifier: 
  StoryTexts:
  - BaseText: You have done well. Now, we are getting close to a third type of encounter-
      a DUNGEON. Dungeons are large areas which must be explored on foot.
    VariantTexts: []
    Speaker: {fileID: 11400000, guid: b7316e420e6b33e41999ba092b1fe073, type: 2}
    Alternatives: []
  - BaseText: Dungeons have different objectives. Many dungeons are optional, and
      can be left as long as no comrades are inside.
    VariantTexts: []
    Speaker: {fileID: 11400000, guid: b7316e420e6b33e41999ba092b1fe073, type: 2}
    Alternatives: []
  - BaseText: Be wary, though- Dungeons are filled with constantly-respawning enemies,
      and if you die in a Dungeon, it costs Supplies to respawn.
    VariantTexts: []
    Speaker: {fileID: 11400000, guid: b7316e420e6b33e41999ba092b1fe073, type: 2}
    Alternatives: []
  - BaseText: In this particular Dungeon, your objective is to find and loot a number
      of Vaults by repairing them.
    VariantTexts: []
    Speaker: {fileID: 11400000, guid: e063144cf422eff408c7e1329f403e15, type: 2}
    Alternatives: []
  - BaseText: The Nebuloid inside are not initially aggressive. Staying out of the
      sight of patrolling defenders and avoiding traps will be the key to success.
    VariantTexts: []
    Speaker: {fileID: 11400000, guid: e063144cf422eff408c7e1329f403e15, type: 2}
    Alternatives: []
  - BaseText: When you are spotted, it is recommended to evacuate the Dungeon immediately.
      Don't be afraid to abort mission if the situation worsens beyond repair.
    VariantTexts: []
    Speaker: {fileID: 11400000, guid: e063144cf422eff408c7e1329f403e15, type: 2}
    Alternatives: []
  ChoicePathDialogs:
  - ChoiceText:
      BaseText: We are prepared to explore the dungeon.
      VariantTexts: []
      Speaker: {fileID: 0}
      Alternatives: []
    Prerequisites: []
    DialogResult: {fileID: 0}
    AlternativeResults: []
    TriggerEvent: {fileID: 11400000, guid: 64f8bf19895c00540b92a62186fa9726, type: 2}
