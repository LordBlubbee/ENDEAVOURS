  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 76cc7d0c0c139b946aecbf9c43b324e5, type: 3}
  m_Name: Tutorial1_Dialog
  m_EditorClassIdentifier: 
  StoryTexts:
  - BaseText: Welcome, Officer. You have narrowly escaped the disaster of the first
      <color=#FF00FF>Starlight Endeavour</color>. All hope for the future rests on
      you now.
    VariantTexts: []
    Speaker: {fileID: 11400000, guid: 9d5807a3bec7ac546807c3709018eaf7, type: 2}
    Alternatives: []
  - BaseText: On your journey, you will find many kinds of encounters on your path.
      Your goal is to survive each of them until you can reach the end of a sector,
      where you can repair and refuel your Drifter.
    VariantTexts: []
    Speaker: {fileID: 11400000, guid: 9d5807a3bec7ac546807c3709018eaf7, type: 2}
    Alternatives: []
  - BaseText: Sometimes, your vessel will come under attack by Nebuloid. To fight
      the creatures of the Nebula, rely on your wits and your Drifter's weapons.
    VariantTexts: []
    Speaker: {fileID: 11400000, guid: 1b51eea723c68724a9eba9f02b38fc91, type: 2}
    Alternatives: []
  - BaseText: Though they cannot easily harm the hull of your Drifter directly, any
      modules they destroy will also damage the integrity of your vessel.
    VariantTexts: []
    Speaker: {fileID: 11400000, guid: 1b51eea723c68724a9eba9f02b38fc91, type: 2}
    Alternatives: []
  - BaseText: Once you are ready to fight them off, select "Prepare for battle" on
      the left.
    VariantTexts: []
    Speaker: {fileID: 11400000, guid: 1b51eea723c68724a9eba9f02b38fc91, type: 2}
    Alternatives: []
  ChoicePathDialogs:
  - ChoiceText:
      BaseText: Prepare for battle.
      VariantTexts: []
      Speaker: {fileID: 0}
      Alternatives: []
    Prerequisites: []
    DialogResult: {fileID: 0}
    AlternativeResults: []
    TriggerEvent: {fileID: 11400000, guid: 3caf131f30f11494dbf455af56a53736, type: 2}
